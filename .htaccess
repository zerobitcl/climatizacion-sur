# ==========================================================================
# Climatización Sur — Apache · SEO técnico
# Canonical estricto: https://www.climatizacionsur.cl/
# ==========================================================================

# --------------------------------------------------------------------------
# Redirecciones 301 canónicas (HTTPS + WWW) — prioridad máxima
# Alineado con <link rel="canonical"> y og:url del sitio
# --------------------------------------------------------------------------
<IfModule mod_rewrite.c>
RewriteEngine On

# 1. Forzar HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Forzar WWW
RewriteCond %{HTTP_HOST} ^climatizacionsur\.cl [NC]
RewriteRule ^(.*)$ https://www.climatizacionsur.cl/$1 [L,R=301]
</IfModule>

DirectoryIndex index.html
AddDefaultCharset UTF-8

# --------------------------------------------------------------------------
# Normalización de URLs (sin duplicar HTTPS/WWW)
# --------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # /index.html → URL limpia
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ https://www.climatizacionsur.cl/ [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+(.+/)index\.html[\s?] [NC]
  RewriteRule ^(.+/)index\.html$ https://www.climatizacionsur.cl/$1 [R=301,L]

  # Directorios sin barra final → con barra (ej. /puerto-montt → /puerto-montt/)
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.+)$ $1/ [R=301,L]
</IfModule>

# --------------------------------------------------------------------------
# Compresión (Core Web Vitals)
# --------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --------------------------------------------------------------------------
# Caché de assets estáticos
# --------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# --------------------------------------------------------------------------
# Seguridad básica
# --------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<Files "robots.txt">
  Require all granted
</Files>
<Files "sitemap.xml">
  Require all granted
</Files>
